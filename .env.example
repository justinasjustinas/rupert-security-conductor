# Environment variables template
# Copy this file to .env and fill in your values

# Gemini API Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Logging Configuration
LOG_LEVEL=INFO

# GCP Configuration (optional for local development)
# GCP_PROJECT_ID=your-gcp-project-id
# GCP_REGION=us-central1

# GitHub API token for fetching diffs when using the GitHub webhook.
# Requires repo read scope. Without this, public-repo diffs still work
# (unauthenticated) but rate limits are tighter.
GITHUB_TOKEN=ghp_your_token_here

# GCS bucket name for persisting scan results and Markdown reports.
# If unset, results are returned in-memory only (no long-term storage).
GCS_BUCKET_NAME=your-bucket-name

# Maximum number of scans that may run concurrently in this process.
# Increase with caution — each scan fires multiple Gemini API calls.
MAX_CONCURRENT_SCANS=5

# Bearer token required on POST /scan.
# If unset, /scan returns 503 unless SCAN_AUTH_DISABLED=true is also set.
SCAN_API_TOKEN=replace-with-a-long-random-string

# Set to true ONLY for local development when you intentionally want /scan open.
# Never set this in production.
SCAN_AUTH_DISABLED=false

# Shared secret for GitHub webhook HMAC-SHA256 signature verification (X-Hub-Signature-256).
# Required — webhooks are rejected if this is not set.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
GITHUB_WEBHOOK_SECRET=replace-with-a-long-random-string

# Shared secret for Bitbucket webhook HMAC-SHA256 signature verification (X-Hub-Signature).
# Required — webhooks are rejected if this is not set.
BITBUCKET_WEBHOOK_SECRET=replace-with-a-long-random-string

# Maximum diff size in bytes accepted by /scan and webhook endpoints (default: 512000 = 500 KB).
MAX_DIFF_SIZE_BYTES=512000

# DATA PRIVACY NOTE:
# Code diffs submitted to this service are sent to Google's Gemini API for analysis.
# This includes any secrets, credentials, or proprietary logic present in the diff.
# Do not use this service for code you are not authorised to share with Google,
# or for diffs that may contain credentials. See README.md for details.
