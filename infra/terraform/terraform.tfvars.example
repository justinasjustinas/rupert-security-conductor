# Terraform variables override file template
# Copy this file to terraform/terraform.tfvars and customize

gcp_project_id         = "your-gcp-project-id"
gcp_region             = "europe-west1"
cloud_run_service_name = "rupert-security-conductor"
cloud_run_service_account_id = "rupert-security-conductor"
github_actions_service_account_id = "rupert-github-actions"
github_workload_identity_pool_id = "github-actions"
github_workload_identity_provider_id = "github-provider"
github_repository_owner = "your-github-org"
github_repository_name  = "rupert-security-conductor"
artifact_registry_repo = "security-conductor"
docker_image_name      = "security-conductor"
docker_image_tag       = "latest"
cloud_run_memory       = "512Mi"
cloud_run_cpu          = "0.5"
cloud_run_timeout      = 300
cloud_run_max_instances = 10

# Optional features — uncomment and set to true to enable.
# deploy.sh sets these automatically based on which env vars are present,
# so you only need these if you are running Terraform directly.

# enable_github_webhook    = false
# enable_bitbucket_webhook = false
# enable_github_token      = false
# gcs_bucket_name          = ""
